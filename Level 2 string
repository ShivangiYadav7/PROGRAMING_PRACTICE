#write a python function to reverse a given string without using builtn in
# slicing methods.


def reverse_string(text):
    reverse_str=""
    for char in text:
        reverse_str = char + reverse_str
    return reverse_str
my_string="abcd"    
print(reverse_string (my_string)) 

# create a function to determine if a given word is a palindrome .

def check_palindrome(word):
    if word==word [::-1]:
        return True
    else:
        return False
    
my_string="madam" 
if check_palindrome(my_string):

   print(f"{my_string} is a palindrom")
else:   
   print(f"{my_string} is not palindrom")

#write a function that accepts a string and returns the count of vowels and consonants
#  separately ignoring non-alphabetic characters.

def count_vowels_consonants(text):
    vowels=0
    consonants=0
    vowels_list="aeiouAEIOU"

    for char in text:
        if char.isalpha():
            if char.lower () in "aeiou":
                vowels  = vowels+1

            else:
                consonants=consonants+1
    return vowels,consonants    
word="Apple"   
v,c=count_vowels_consonants(word)
print(f"vowels:{v},consonants:{c}")


